# Server side only. Never reaches the browser.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# This one is allowed to reach the browser because the Finnhub
# WebSocket connects directly from the page. Get a free key at
# https://finnhub.io. Do not commit your real .env file.
VITE_FINNHUB_KEY=your-finnhub-key-here

# The SEC asks automated tools to identify themselves with a contact
# email when fetching EDGAR feeds. Any email you own works.
SEC_CONTACT_EMAIL=you@example.com
