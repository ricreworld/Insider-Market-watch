# Server side only. Never reach the browser. You need at least one of
# these for the AI buttons; everything else works with none of them.
# The app tries them in this order: Gemini, then Groq, then Anthropic.
# The Gemini brain uses ONE key. Put your paid Gemini key in either slot;
# GEMINI_PAID_API_KEY wins if both are set. Get a key at
# https://aistudio.google.com. The app auto-falls to lighter Gemini
# models, and drops web-search grounding if a model rejects it.
GEMINI_API_KEY=your-gemini-key-here
# Same Gemini brain, alternate slot. Set this OR GEMINI_API_KEY, not both.
GEMINI_PAID_API_KEY=your-paid-gemini-key-here
# Second free brain, no card, generous limits, https://console.groq.com.
# No live web search, but keeps the app alive when Gemini's daily free
# quota is used up. Great free headroom.
GROQ_API_KEY=your-groq-key-here
# Paid brain, web search, https://console.anthropic.com. Last resort.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# This one is allowed to reach the browser because the Finnhub
# WebSocket connects directly from the page. Get a free key at
# https://finnhub.io. Do not commit your real .env file.
VITE_FINNHUB_KEY=your-finnhub-key-here

# The SEC asks automated tools to identify themselves with a contact
# email when fetching EDGAR feeds. Any email you own works.
SEC_CONTACT_EMAIL=you@example.com

# Powers the earnings calendar on the Live wire tab. Free key issued
# instantly at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your-alphavantage-key-here

# Optional. The Reddit chatter layer works with NO credentials via a free
# community archive fallback. For fresher official-API data, register a
# Reddit app (see api reddit setup) and set both of these. Without them,
# the app quietly uses the fallback.
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
